# ─────────────────────────────────────────────────────────────────
# KRCE Bus Tracking System — Environment Variables Template
# Copy this file to .env for local development
# Set these variables in Render dashboard for production
# NEVER commit actual secret values to Git
# ─────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Format: mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# MongoDB database name (default: krce_bus)
MONGO_DB_NAME=krce_bus

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# MUST be set in production — app refuses to start if missing on Render
JWT_SECRET=your-very-long-random-secret-here-at-least-32-characters

# Comma-separated list of allowed frontend origins
# Use * for local development only
ALLOWED_ORIGINS=*

# Environment — set to "production" on Render
# Render auto-sets RENDER=true, which the app also detects
ENVIRONMENT=development

# Sentry DSN for error monitoring (optional — leave blank to disable)
SENTRY_DSN=

# Port — Render sets this automatically via $PORT; only needed for local override
PORT=8000
