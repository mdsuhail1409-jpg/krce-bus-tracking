<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext (HTTP) to local dev server during development -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.245.235.53</domain>
    </domain-config>
    <!-- Also allow emulator loopback for testing on AVD -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
